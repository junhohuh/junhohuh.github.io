---
import type { Project } from '../data/projects';

interface Props {
	project: Project;
}

const { project } = Astro.props;
---

<article
	class="rounded-xl border border-slate-200/90 bg-white p-6 shadow-sm shadow-slate-900/5 transition-all duration-200 hover:shadow-md hover:shadow-slate-900/10 hover:scale-105 hover:-translate-y-1 animate-fadeInUp"
>
	<h2 class="text-lg font-semibold text-slate-900">{project.title}</h2>
	<p class="mt-2 text-sm leading-relaxed text-slate-600">{project.summary}</p>
	<ul class="mt-3 flex flex-wrap gap-2" aria-label="Technologies">
		{
			project.tech.map((t) => (
				<li class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-700">{t}</li>
			))
		}
	</ul>
	<div class="mt-4 flex flex-wrap gap-3 text-sm font-medium">
		{
			project.repoUrl && (
				<a href={project.repoUrl} class="text-teal-800 hover:text-teal-900" target="_blank" rel="noopener noreferrer">
					Repository
				</a>
			)
		}
		{
			project.demoUrl && (
				<a href={project.demoUrl} class="text-teal-800 hover:text-teal-900" target="_blank" rel="noopener noreferrer">
					Live demo
				</a>
			)
		}
	</div>
</article>
