---
const pathname = Astro.url.pathname;

const nav = [
	{ href: '/', label: 'Home', match: (p: string) => p === '/' },
	{ href: '/about', label: 'About', match: (p: string) => p === '/about' },
	{ href: '/projects', label: 'Projects', match: (p: string) => p === '/projects' },
] as const;
---

<header class="border-b border-slate-200/80 bg-white/90 backdrop-blur-sm">
	<div class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-4 px-4 py-4">
		<a href="/" class="text-lg font-semibold tracking-tight text-slate-900">Junho Huh</a>
		<nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm font-medium" aria-label="Primary">
			{
				nav.map(({ href, label, match }) => (
					<a
						href={href}
						class:list={[
							'transition-colors',
							match(pathname) ? 'text-teal-800' : 'text-slate-600 hover:text-slate-900',
						]}
						aria-current={match(pathname) ? 'page' : undefined}
					>
						{label}
					</a>
				))
			}
			<a
				href="/resume.pdf"
				class="text-slate-600 transition-colors hover:text-slate-900"
				target="_blank"
				rel="noopener noreferrer"
			>
				Resume
			</a>
		</nav>
	</div>
</header>
