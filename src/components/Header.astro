<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur-sm">
	<div class="flex flex-wrap items-center justify-between gap-4 px-8 py-4">
		<a href="#home" class="text-lg font-semibold tracking-tight text-slate-900">Junho Huh</a>
		<nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm font-medium" aria-label="Primary">
			<a href="#home" class="nav-link text-slate-600 transition-colors hover:text-slate-900" data-section="home">Home</a>
			<a href="#about" class="nav-link text-slate-600 transition-colors hover:text-slate-900" data-section="about">About</a>
			<a href="#experience" class="nav-link text-slate-600 transition-colors hover:text-slate-900" data-section="experience">Experience</a>
			<a href="#projects" class="nav-link text-slate-600 transition-colors hover:text-slate-900" data-section="projects">Projects</a>
			<a
				href="/resume.pdf"
				class="text-slate-600 transition-colors hover:text-slate-900"
				target="_blank"
				rel="noopener noreferrer"
			>
				Resume
			</a>
		</nav>
	</div>
</header>

<script>
	const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link');
	const sections = document.querySelectorAll<HTMLElement>('section[id]');

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					links.forEach((link) => {
						const active = link.dataset.section === entry.target.id;
						link.classList.toggle('text-teal-800', active);
						link.classList.toggle('font-semibold', active);
						link.classList.toggle('text-slate-600', !active);
					});
				}
			});
		},
		{ rootMargin: '-40% 0px -55% 0px' }
	);

	sections.forEach((section) => observer.observe(section));
</script>
