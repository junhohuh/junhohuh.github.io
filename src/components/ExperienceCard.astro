---
import type { Experience } from '../data/experiences';

interface Props {
	experience: Experience;
}

const { experience } = Astro.props;
---

<article
	class="rounded-xl border border-slate-200/90 bg-white p-6 shadow-sm shadow-slate-900/5 transition-all duration-200 hover:shadow-md hover:shadow-slate-900/10 hover:scale-105 hover:-translate-y-1 animate-fadeInUp"
>
	<div class="flex flex-wrap items-baseline justify-between gap-2">
		<h2 class="text-lg font-semibold text-slate-900">{experience.role}</h2>
		<span class="text-sm text-slate-500">{experience.period}</span>
	</div>
	<p class="mt-1 text-sm font-medium text-teal-800">{experience.company}{experience.team ? ` · ${experience.team}` : ''}</p>
	<ul class="mt-3 list-disc space-y-1 pl-5 text-sm leading-relaxed text-slate-600">
		{experience.bullets.map((b) => <li>{b}</li>)}
	</ul>
</article>
