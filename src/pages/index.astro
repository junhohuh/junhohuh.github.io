---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import PhotoCarousel from '../components/PhotoCarousel.astro';
import { projects } from '../data/projects';
import { experiences } from '../data/experiences';

// Add your photos here (you can add multiple photos for the carousel)
const aboutPhotos: string[] = [
	/*
	'/IMG_3115.JPG',
	'/IMG_1345.JPG',
	'/IMG_1464.JPG',
	'/IMG_3124.JPG'
	Intentionally Commented Out, will do later*/
];
---

<Layout title="Junho Huh" description="Student portfolio: bio, projects, and resume.">

	<!-- Home -->
	<section id="home" class="flex min-h-screen flex-col items-center px-8 pt-[30vh] text-center">
		<h1 class="font-display text-7xl tracking-tight text-slate-900 md:text-8xl font-semibold">Hi, I'm Junho.</h1>
		<p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-600">
			I'm a student who enjoys building clear, reliable software. Scroll down to learn more about me, my experience, and my projects.
		</p>
		<div class="mt-8 flex flex-wrap justify-center gap-3">
			<a
				href="#about"
				class="rounded-lg bg-teal-800 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-teal-900"
			>
				About me
			</a>
		</div>
		<!-- Scroll hint -->
		<div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce">
			<svg class="h-6 w-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
			</svg>
		</div>
	</section>

	<!-- About -->
	<section id="about" class="border-t border-slate-200/50 px-8 py-32">
		<div class="mx-auto max-w-6xl">
			<h2 class="font-display text-6xl tracking-tight text-slate-900 md:text-7xl mb-20">a bit more about me...</h2>

			<div class="grid gap-6 grid-cols-2 md:grid-cols-4 auto-rows-[280px] md:auto-rows-[320px]">
				<!-- Photo carousel (2x2) -->
				<div class="md:col-span-2 md:row-span-2">
					<PhotoCarousel photos={aboutPhotos} />
				</div>

				<!-- Bio item -->
				<div class="md:col-span-2 bg-white rounded-2xl border border-slate-200/50 p-6 flex flex-col justify-between">
					<div>
						<h3 class="text-sm font-semibold uppercase tracking-wide text-teal-800 mb-3">Bio</h3>
						<p class="text-sm leading-relaxed text-slate-600">
							Replace with your story: focus area, what you're looking for next, concrete interests.
						</p>
					</div>
				</div>

				<!-- Small photo item -->
				<div class="bg-gradient-to-br from-slate-100 to-slate-50 rounded-2xl border border-slate-200/50 overflow-hidden flex items-center justify-center">
					<div class="text-center">
						<div class="text-3xl">📷</div>
						<p class="text-xs text-slate-400 mt-1">Photo</p>
					</div>
				</div>

				<!-- Small accent item -->
				<div class="bg-gradient-to-br from-slate-100 to-slate-50 rounded-2xl border border-slate-200/50 overflow-hidden flex items-center justify-center">
					<div class="text-center">
						<div class="text-3xl">🎯</div>
						<p class="text-xs text-slate-400 mt-1">Photo</p>
					</div>
				</div>

				<!-- Spacer item -->
				<div class="bg-gradient-to-br from-slate-100 to-slate-50 rounded-2xl border border-slate-200/50 overflow-hidden flex items-center justify-center">
					<div class="text-center">
						<div class="text-3xl">🌟</div>
						<p class="text-xs text-slate-400 mt-1">Photo</p>
					</div>
				</div>

				<!-- Connect item (1x1, bottom right) -->
				<div class="bg-white rounded-2xl border border-slate-200/50 p-6 flex flex-col justify-between">
					<h3 class="text-sm font-semibold uppercase tracking-wide text-teal-800 mb-4">Connect</h3>
					<div class="space-y-3">
						<p>
							<a
								href="mailto:junhohuh1234@gmail.com"
								class="font-medium text-teal-800 underline decoration-teal-800/25 underline-offset-2 hover:decoration-teal-800 text-sm break-all"
							>junhohuh1234@gmail.com</a>
						</p>
						<div class="flex gap-3 text-xs font-medium flex-wrap">
							<a href="https://github.com/junhohuh" class="text-teal-800 hover:text-teal-900 transition-colors" target="_blank" rel="noopener noreferrer">GitHub</a>
							<a href="https://www.linkedin.com/in/junhohuh0930" class="text-teal-800 hover:text-teal-900 transition-colors" target="_blank" rel="noopener noreferrer">LinkedIn</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Experience -->
	<section id="experience" class="min-h-screen border-t border-slate-200/50 px-8 py-32">
		<div class="mx-auto max-w-3xl">
			<h2 class="font-display text-6xl tracking-tight text-slate-900 md:text-7xl mb-16">my journey so far</h2>
			<div class="flex flex-col gap-8">
				{experiences.map((exp) => <ExperienceCard experience={exp} />)}
			</div>
		</div>
	</section>

	<!-- Projects -->
	<section id="projects" class="min-h-screen border-t border-slate-200/50 px-8 py-32">
		<div class="mx-auto max-w-4xl">
			<h2 class="font-display text-6xl tracking-tight text-slate-900 md:text-7xl mb-16">learn more about my projects</h2>
			<div class="grid gap-8 sm:grid-cols-2">
				{projects.map((project) => <ProjectCard project={project} />)}
			</div>
		</div>
	</section>

</Layout>
